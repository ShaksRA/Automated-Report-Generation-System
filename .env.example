# ── API Settings ─────────────────────────────────────────────────────────────
API_BASE_URL=https://jsonplaceholder.typicode.com
API_TIMEOUT=30
API_RETRY_MAX=3

# ── Scheduler ────────────────────────────────────────────────────────────────
SCHEDULE_DAY=monday
SCHEDULE_TIME=08:00

# ── Email (optional) ──────────────────────────────────────────────────────────
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_TO=manager@company.com,team@company.com

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
